# Email delivery for the RFQ form (Section 8). Provider TBD:
# [CONFIRM provider: Resend vs existing Google Workspace SMTP for @soilagri.com]
RESEND_API_KEY=

# Comma-separated list of RFQ notification recipients.
# UNRESOLVED — see content/leadership.ts and Section 5.3: only
# vivekvhora@soilagri.com is confirmed consistent across client messages.
RFQ_NOTIFY_TO=

# Sender address for RFQ auto-acknowledgements, e.g. no-reply@soilagri.com
# [CONFIRM domain auth: SPF, DKIM, DMARC must pass before launch]
RFQ_REPLY_FROM=

# Production site URL, e.g. https://soilagri.com [CONFIRM production domain]
NEXT_PUBLIC_SITE_URL=

# Secret used to key the RFQ rate limiter
RATE_LIMIT_SECRET=

# Optional. Free key from alphavantage.co — powers the live Wheat/Corn
# benchmark rates in the homepage Market Watch section. Falls back to
# the shared "demo" key if unset (fine for dev, rate-limits fast in prod).
ALPHA_VANTAGE_API_KEY=
