# Email delivery for the RFQ form, via Brevo's transactional email API.
# Create a key at https://app.brevo.com/settings/keys/api
BREVO_API_KEY=

# Comma-separated list of RFQ notification recipients.
RFQ_NOTIFY_TO=vivekvohra@soilagri.com

# Sender address for RFQ notifications and auto-acknowledgements.
# [CONFIRM domain auth: SPF, DKIM, DMARC must pass in Brevo before launch]
RFQ_REPLY_FROM=

# Production site URL, e.g. https://soilagri.com [CONFIRM production domain]
NEXT_PUBLIC_SITE_URL=

# Secret used to key the RFQ rate limiter
RATE_LIMIT_SECRET=

# Optional. Free key from alphavantage.co — powers the live Wheat/Corn
# benchmark rates in the homepage Market Watch section. Falls back to
# the shared "demo" key if unset (fine for dev, rate-limits fast in prod).
ALPHA_VANTAGE_API_KEY=

# ---------------------------------------------------------------------
# RFQ CRM (/admin) — optional. Absent means the CRM shows a "not
# configured" screen instead of crashing; the public RFQ form still works.
# ---------------------------------------------------------------------

# Vercel Postgres connection string. From your Vercel dashboard:
# Storage -> Create Database -> Postgres -> .env.local tab -> copy POSTGRES_URL.
POSTGRES_URL=

# Shared password for the /admin CRM login (single operator, not a
# per-user account system — keep it as strong as any other prod secret).
ADMIN_PASSWORD=

# Random 32+ character string used to sign the admin session cookie.
# Generate one with: openssl rand -hex 32
ADMIN_SESSION_SECRET=

# ---------------------------------------------------------------------
# Contact page map — optional. Absent means Contact falls back to a
# plain office list instead of the interactive map.
# ---------------------------------------------------------------------

# Google Maps JavaScript API key (public — this is the client-side key,
# not a secret; restrict it by HTTP referrer in Google Cloud Console to
# your production domain). Enable the "Maps JavaScript API".
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
